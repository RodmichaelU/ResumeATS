# LLM backend — Ollama only, no API keys needed
LLM_PROVIDER=ollama
DEFAULT_MODEL=gemma3:4b
OLLAMA_HOST=http://localhost:11434

# Path to the vendored hiring-agent submodule, relative to backend/
HIRING_AGENT_DIR=../vendor/hiring-agent

# Max seconds to wait for a single evaluation job before marking it failed
JOB_TIMEOUT_SECONDS=600

# Frontend origin allowed to call this API (Vite dev server default)
CORS_ORIGIN=http://localhost:5173

# Optional. If a resume includes a GitHub profile link, hiring-agent enriches the
# evaluation with GitHub data, making one API call per repo. Unauthenticated GitHub
# API calls are capped at 60/hour, which can exhaust quickly for profiles with several
# repos. A token (no special scopes needed for public data) raises this to 5000/hour.
# Create one at https://github.com/settings/tokens
# GITHUB_TOKEN=
